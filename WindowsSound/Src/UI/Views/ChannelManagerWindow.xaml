<Window x:Class="WindowsSound.UI.Views.ChannelManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="声道管理器" Height="700" Width="1000"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">

    <Window.Resources>
        <Style TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Padding" Value="5"/>
            <Setter Property="Margin" Value="5"/>
        </Style>

        <DataTemplate x:Key="ChannelItemTemplate">
            <Border Background="#2a2a2a" BorderBrush="#3a3a3a" BorderThickness="1"
                    CornerRadius="5" Padding="10" Margin="5"
                    Width="120" Height="80"
                    AllowDrop="True"
                    Drop="ChannelItem_Drop"
                    DragEnter="ChannelItem_DragEnter"
                    DragLeave="ChannelItem_DragLeave">
                <StackPanel>
                    <TextBlock Text="{Binding Channel}" FontSize="12" FontWeight="Bold" Foreground="#e0e0e0"/>
                    <TextBlock Text="{Binding DeviceId, Converter={StaticResource DeviceIdToNameConverter}}"
                               FontSize="10" Foreground="#a0a0a0" TextWrapping="Wrap" Margin="0,5,0,0"/>
                    <TextBlock Text="{Binding DelayMs, StringFormat=延迟: {0}ms}"
                               FontSize="9" Foreground="#80c080" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="DeviceItemTemplate">
            <Border Background="#1a3a1a" BorderBrush="#2a5a2a" BorderThickness="1"
                    CornerRadius="5" Padding="10" Margin="5"
                    Width="140" Height="70"
                    MouseLeftButtonDown="DeviceItem_MouseLeftButtonDown"
                    Cursor="Hand">
                <StackPanel>
                    <TextBlock Text="{Binding Alias}" FontSize="11" FontWeight="Bold" Foreground="#e0e0e0"/>
                    <TextBlock Text="{Binding DeviceId, Converter={StaticResource ShortIdConverter}}"
                               FontSize="9" Foreground="#a0a0a0" Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding LatencyMs, StringFormat=延迟: {0}ms}"
                               FontSize="9" Foreground="#80c080" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="#1e1e1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <ToolBar Grid.Row="0" Background="#2d2d2d">
            <Button Content="保存配置" Command="{Binding SaveCommand}"/>
            <Separator/>
            <Button Content="播放测试音" Click="PlayAllChannelsTest_Click"/>
            <Button Content="停止测试音" Command="{Binding StopTestToneCommand}"/>
            <Separator/>
            <Button Content="延迟校准" Click="Calibration_Click"/>
        </ToolBar>

        <!-- 场景选择 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Text="场景:" VerticalAlignment="Center" Foreground="#e0e0e0"/>
            <ComboBox Grid.Column="1" ItemsSource="{Binding Scenes}"
                      SelectedItem="{Binding SelectedScene}"
                      DisplayMemberPath="SceneName"/>

            <TextBlock Grid.Column="3" Text="新增场景:" VerticalAlignment="Center" Foreground="#e0e0e0"/>
            <TextBox Grid.Column="4" Text="{Binding NewSceneName, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                        <Style.Triggers>
                            <Trigger Property="Text" Value="">
                                <Setter Property="Background">
                                    <Setter.Value>
                                        <VisualBrush Stretch="None" AlignmentX="Left">
                                            <VisualBrush.Visual>
                                                <TextBlock Text="场景名称" Foreground="Gray" Margin="5,0,0,0"/>
                                            </VisualBrush.Visual>
                                        </VisualBrush>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TextBox.Style>
            </TextBox>

            <Button Grid.Column="6" Content="创建" Command="{Binding CreateSceneCommand}"/>

            <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="删除场景" Command="{Binding DeleteSceneCommand}"
                        CommandParameter="{Binding SelectedScene}"/>
            </StackPanel>
        </Grid>

        <!-- 主内容区 -->
        <Grid Grid.Row="2" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：可用设备列表 -->
            <Border Grid.Column="0" Background="#252525" BorderBrush="#3a3a3a" BorderThickness="1"
                    CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock Text="可用设备" FontSize="14" FontWeight="Bold" Foreground="#e0e0e0" Margin="0,0,0,10"/>
                    <TextBlock Text="拖拽设备到右侧声道" FontSize="11" Foreground="#808080" Margin="0,0,0,10"/>

                    <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="400">
                        <ItemsControl ItemsSource="{Binding AvailableDevices}"
                                      ItemTemplate="{StaticResource DeviceItemTemplate}"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <!-- 右侧：声道配置 -->
            <Border Grid.Column="1" Background="#252525" BorderBrush="#3a3a3a" BorderThickness="1"
                    CornerRadius="5" Padding="10" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 配置选择 -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="150"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="配置:" VerticalAlignment="Center" Foreground="#e0e0e0"/>
                        <ComboBox Grid.Column="1" ItemsSource="{Binding SelectedScene.Configurations}"
                                  SelectedItem="{Binding SelectedConfiguration}"
                                  DisplayMemberPath="Name"/>

                        <TextBlock Grid.Column="3" Text="声道布局:" VerticalAlignment="Center" Foreground="#e0e0e0"/>
                        <ComboBox Grid.Column="4" ItemsSource="{Binding Layouts}"
                                  SelectedItem="{Binding SelectedLayout}"
                                  SelectionChanged="LayoutComboBox_SelectionChanged"/>

                        <Button Grid.Column="6" Content="添加配置" Command="{Binding AddConfigurationCommand}"
                                Click="AddConfig_Click"/>
                    </Grid>

                    <!-- 声道分配区域 -->
                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,10,0,0">
                        <ItemsControl ItemsSource="{Binding ChannelAssignments}"
                                      ItemTemplate="{StaticResource ChannelItemTemplate}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部状态栏 -->
        <StatusBar Grid.Row="3" Background="#2d2d2d">
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedScene.SceneName, StringFormat=场景: {0}}"
                           Foreground="#a0a0a0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock Text="{Binding SelectedConfiguration.Name, StringFormat=配置: {0}}"
                           Foreground="#a0a0a0"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="就绪" Foreground="#a0a0a0"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
