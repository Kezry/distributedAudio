<Window x:Class="DistributedAudio.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="分布式音频系统" Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="MinWidth" Value="100"/>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDD"/>
        </Style>

        <DataTemplate x:Key="DeviceTemplate">
            <Grid Margin="5">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="{Binding DisplayName}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding Host}" FontSize="11" Foreground="Gray"/>
                    <TextBlock FontSize="11">
                        <Run Text="延迟: "/>
                        <Run Text="{Binding Latency}" FontWeight="Bold"/>
                        <Run Text="ms"/>
                    </TextBlock>
                </StackPanel>

                <Button Grid.Column="1"
                        Content="添加"
                        Command="{Binding DataContext.SelectDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                        CommandParameter="{Binding}"
                        Margin="5"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ActiveDeviceTemplate">
            <Border BorderBrush="#DDD" BorderThickness="1" Margin="5" Padding="10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="{Binding Device.DisplayName}" FontWeight="Bold"/>
                        <TextBlock Text="{Binding AssignedChannels}" FontSize="11" Foreground="Gray"/>
                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                            <Ellipse Width="10" Height="10" Margin="0,0,5,0">
                                <Ellipse.Fill>
                                    <SolidColorBrush Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                                </Ellipse.Fill>
                            </Ellipse>
                            <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolToStatusConverter}}" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0">
                        <TextBlock Text="音量:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <Slider Value="{Binding Volume}" Minimum="0" Maximum="100" Width="100"/>
                        <TextBlock Text="{Binding Volume}" VerticalAlignment="Center" Margin="5,0,0,0" MinWidth="30"/>
                    </StackPanel>

                    <Button Grid.Column="2"
                            Content="移除"
                            Command="{Binding DataContext.RemoveDeviceCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Control Panel -->
        <Border Grid.Row="0" BorderBrush="#DDD" BorderThickness="0,0,0,1" Padding="15" Background="White">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Content="扫描设备" Command="{Binding StartScanCommand}"/>
                    <Button Content="停止扫描" Command="{Binding StopScanCommand}"/>
                    <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}"/>
                    <Button Content="开始传输" Command="{Binding StartStreamingCommand}" Background="#4CAF50" Foreground="White"/>
                    <Button Content="停止传输" Command="{Binding StopStreamingCommand}" Background="#F44336" Foreground="White"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="20,0">
                    <TextBlock Text="声道配置:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <ComboBox ItemsSource="{Binding ChannelConfigurations}"
                              SelectedItem="{Binding SelectedChannelConfiguration}"
                              Width="150"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusMessage}" FontWeight="Bold" Foreground="#333"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="活动设备: " FontSize="11"/>
                        <TextBlock Text="{Binding ActiveDeviceCount}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="  |  " FontSize="11"/>
                        <TextBlock Text="数据包: " FontSize="11"/>
                        <TextBlock Text="{Binding TotalPacketsSent}" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="  |  " FontSize="11"/>
                        <TextBlock Text="音频电平: " FontSize="11"/>
                        <TextBlock Text="{Binding CurrentAudioLevel, StringFormat={}{0:F1}%}" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" Margin="15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Discovered Devices -->
            <Border Grid.Column="0" BorderBrush="#DDD" BorderThickness="1" Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                        <TextBlock Text="发现的设备" FontWeight="Bold" FontSize="14"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding DiscoveredDevices}"
                             ItemTemplate="{StaticResource DeviceTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>

            <!-- Active Devices -->
            <Border Grid.Column="1" BorderBrush="#DDD" BorderThickness="1,1,1,0" Background="White" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F5F5F5" Padding="10" BorderBrush="#DDD" BorderThickness="0,0,0,1">
                        <TextBlock Text="活动设备" FontWeight="Bold" FontSize="14"/>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding ActiveDevices}"
                             ItemTemplate="{StaticResource ActiveDeviceTemplate}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2" BorderBrush="#DDD" BorderThickness="0,1,0,0" Padding="10,5" Background="White">
            <Grid>
                <TextBlock Text="© 2025 Distributed Audio System | CC BY-NC 4.0" FontSize="11" Foreground="Gray" HorizontalAlignment="Left"/>
                <TextBlock FontSize="11" Foreground="Gray" HorizontalAlignment="Right">
                    <Run Text="版本: "/>
                    <Run Text="1.0.0"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
